<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="@color/background_dark"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- SOS Button (top-left, prominent) -->
    <TextView
        android:id="@+id/sos_button"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:gravity="center"
        android:paddingHorizontal="20dp"
        android:text="@string/sos_label"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:background="@drawable/bg_sos_button"
        android:layout_marginTop="12dp"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Battery Indicator (top-right) -->
    <LinearLayout
        android:id="@+id/battery_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_battery_indicator"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="6dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/battery_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="100%"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginEnd="4dp" />

        <ProgressBar
            android:id="@+id/battery_progress"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="40dp"
            android:layout_height="6dp"
            android:max="100"
            android:progress="100"
            android:progressDrawable="@drawable/bg_speed_slider_track" />
    </LinearLayout>

    <!-- Timer display (below SOS, top-left) -->
    <TextView
        android:id="@+id/timer_display"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#FF9736"
        android:textSize="13sp"
        android:textStyle="bold"
        android:visibility="gone"
        android:background="@drawable/bg_battery_indicator"
        android:padding="6dp"
        android:layout_marginTop="4dp"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toBottomOf="@id/sos_button"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Mode label (below battery) -->
    <TextView
        android:id="@+id/mode_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/mode_normal"
        android:textColor="#888888"
        android:textSize="12sp"
        android:letterSpacing="0.15"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/battery_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Vertical Line -->
    <View
        android:id="@+id/line_5"
        android:layout_width="5dp"
        android:layout_height="0dp"
        android:background="@drawable/lines"
        app:layout_constraintTop_toBottomOf="@id/mode_label"
        app:layout_constraintBottom_toTopOf="@id/lightBulb"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_default="percent"
        app:layout_constraintHeight_percent="0.32" />

    <!-- Transparent Ellipses (glow effect) -->
    <View
        android:id="@+id/ellipse_1"
        android:layout_width="150dp"
        android:layout_height="148dp"
        android:background="@drawable/one"
        app:layout_constraintTop_toTopOf="@id/lightBulb"
        app:layout_constraintBottom_toBottomOf="@id/lightBulb"
        app:layout_constraintStart_toStartOf="@id/lightBulb"
        app:layout_constraintEnd_toEndOf="@id/lightBulb" />

    <View
        android:id="@+id/ellipse_2"
        android:layout_width="200dp"
        android:layout_height="197dp"
        android:background="@drawable/one"
        android:alpha="0.1"
        app:layout_constraintTop_toTopOf="@id/ellipse_1"
        app:layout_constraintBottom_toBottomOf="@id/ellipse_1"
        app:layout_constraintStart_toStartOf="@id/ellipse_1"
        app:layout_constraintEnd_toEndOf="@id/ellipse_1" />

    <View
        android:id="@+id/ellipse_3"
        android:layout_width="250dp"
        android:layout_height="246dp"
        app:layout_constraintTop_toTopOf="@id/ellipse_2"
        app:layout_constraintBottom_toBottomOf="@id/ellipse_2"
        app:layout_constraintStart_toStartOf="@id/ellipse_2"
        app:layout_constraintEnd_toEndOf="@id/ellipse_2"
        android:background="@drawable/one"
        android:alpha="0.05" />

    <View
        android:id="@+id/ellipse_4"
        android:layout_width="300dp"
        android:layout_height="295dp"
        app:layout_constraintTop_toTopOf="@id/ellipse_3"
        app:layout_constraintBottom_toBottomOf="@id/ellipse_3"
        app:layout_constraintStart_toStartOf="@id/ellipse_3"
        app:layout_constraintEnd_toEndOf="@id/ellipse_3"
        android:background="@drawable/one"
        android:alpha="0.1" />

    <!-- Light Bulb Icon -->
    <ImageView
        android:id="@+id/lightBulb"
        android:layout_width="76dp"
        android:layout_height="93dp"
        android:src="@drawable/bulb_off"
        android:contentDescription="@string/flashlight_bulb"
        app:layout_constraintTop_toBottomOf="@id/line_5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Screen Light Overlay (for screen flashlight mode) -->
    <View
        android:id="@+id/screen_light_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF"
        android:visibility="gone"
        android:elevation="100dp"
        android:clickable="true"
        android:focusable="true" />

    <!-- Screen Light Close Button -->
    <TextView
        android:id="@+id/screen_light_close"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/tap_to_close"
        android:textColor="#333333"
        android:textSize="16sp"
        android:textStyle="bold"
        android:visibility="gone"
        android:elevation="101dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="60dp" />

    <!-- Speed control for Strobe mode -->
    <LinearLayout
        android:id="@+id/strobe_speed_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="40dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/ellipse_4"
        app:layout_constraintBottom_toTopOf="@id/timer_section">

        <TextView
            android:id="@+id/speed_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/strobe_speed"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <SeekBar
            android:id="@+id/speed_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:min="1"
            android:max="20"
            android:progress="5"
            android:progressDrawable="@drawable/bg_speed_slider_track"
            android:thumbTint="#FF9736" />
    </LinearLayout>

    <!-- Timer Section -->
    <LinearLayout
        android:id="@+id/timer_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/mode_selector_container">

        <TextView
            android:id="@+id/timer_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_off_timer"
            android:textColor="#888888"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/timer_off"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:text="@string/timer_off_label"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_timer_button"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/timer_1min"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:text="@string/timer_1min"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:background="@drawable/bg_timer_button"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/timer_5min"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:text="@string/timer_5min"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:background="@drawable/bg_timer_button"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/timer_15min"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:text="@string/timer_15min"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:background="@drawable/bg_timer_button"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/timer_custom"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:text="@string/timer_custom"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:background="@drawable/bg_timer_button" />
        </LinearLayout>
    </LinearLayout>

    <!-- Mode Selector (bottom) -->
    <LinearLayout
        android:id="@+id/mode_selector_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/bg_mode_container"
        android:padding="4dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/outer_container">

        <TextView
            android:id="@+id/mode_normal"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="@string/mode_normal"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/bg_mode_button" />

        <TextView
            android:id="@+id/mode_strobe"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="@string/mode_strobe"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:background="@drawable/bg_mode_button"
            android:layout_marginStart="4dp" />

        <TextView
            android:id="@+id/mode_screen"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="@string/mode_screen"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:background="@drawable/bg_mode_button"
            android:layout_marginStart="4dp" />
    </LinearLayout>

    <!-- Shake / On-Off Button (bottom) -->
    <RelativeLayout
        android:id="@+id/outer_container"
        android:layout_width="136dp"
        android:layout_height="36dp"
        android:background="@drawable/button"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:id="@+id/shake_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/shake_text"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/shake"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <RelativeLayout
                android:id="@+id/off_button"
                android:layout_width="54dp"
                android:layout_height="28dp"
                android:clipToOutline="true"
                android:background="@drawable/frame_shake"
                android:layout_gravity="center_vertical"
                android:layout_marginVertical="5dp"
                android:layout_marginEnd="6dp">

                <TextView
                    android:id="@+id/status"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="@string/status_off"
                    android:textColor="#121212"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </RelativeLayout>
        </LinearLayout>
    </RelativeLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
