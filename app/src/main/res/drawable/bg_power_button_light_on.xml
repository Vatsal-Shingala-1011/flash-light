<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow ring -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#33FF9736" />
            <size android:width="72dp" android:height="72dp" />
        </shape>
    </item>
    <!-- Inner circle -->
    <item android:left="4dp" android:top="4dp" android:right="4dp" android:bottom="4dp">
        <shape android:shape="oval">
            <solid android:color="#FFF5E6" />
            <stroke android:width="2.5dp" android:color="#FF9736" />
            <size android:width="64dp" android:height="64dp" />
        </shape>
    </item>
</layer-list>
