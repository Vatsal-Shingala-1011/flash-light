<?xml version="1.0" encoding="utf-8"?>
<!-- Large circular power button – OFF state -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow ring -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#11FFFFFF" />
            <size android:width="72dp" android:height="72dp" />
        </shape>
    </item>
    <!-- Inner circle -->
    <item android:left="3dp" android:top="3dp" android:right="3dp" android:bottom="3dp">
        <shape android:shape="oval">
            <solid android:color="#1A1A1A" />
            <stroke android:width="2dp" android:color="#444444" />
        </shape>
    </item>
</layer-list>
